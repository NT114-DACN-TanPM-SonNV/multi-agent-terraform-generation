# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek                # deepseek (default) | nvidia
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-pro       # ghi rõ snapshot khi báo cáo metrics (v4-pro hoặc v4-flash)
# NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
LLM_TIMEOUT=300                      # v4-pro cần 300s+ cho complex reasoning
LLM_RETRIES=3
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2                  # >0 để pass@k/bootstrap có biến thiên (validator A4 vẫn tất định)
# Per-agent caps — KHÔNG fallback về LLM_MAX_TOKENS, phải set tường minh. Default code:
# ARCHI=2048 SECU=512 ENGI=4096 VAL=256 DEPLOY=256 — quá nhỏ cho v4-pro / plan nhiều resource.
LLM_MAX_TOKENS_ARCHI=8192
LLM_MAX_TOKENS_ENGI=8192
LLM_MAX_TOKENS_SECU=6144             # A2 JSON map nhiều resource (label dài) → cần headroom, tránh truncate → mất security
LLM_MAX_TOKENS_VAL=2048
LLM_MAX_TOKENS_DEPLOY=2048

# ── AWS (cần cho terraform plan/apply + Rego semantic eval) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Terraform ─────────────────────────────────────────────────────────────────
TF_PLAN_TIMEOUT=300                  # Terraform plan timeout (giây)
TF_LOCK_TIMEOUT=60s                  # State lock timeout (tránh deadlock)
TF_INPUT=false                        # Non-interactive mode (required cho automation)
TF_IN_AUTOMATION=true                 # Automation mode (skip unnecessary output)
TF_PLUGIN_CACHE_DIR=.tf_plugin_cache  # Per-worker cache (prevents contention)

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_MAX_ATTEMPTS=5                    # Retry attempts cho AWS API calls (tránh throttle)
